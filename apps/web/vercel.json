{
  "version": 2,
  "cleanUrls": false,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/signup(?:/(.*))?", "dest": "/signup.html" },
    { "src": "/start(?:/(.*))?", "dest": "/start.html" },
    { "src": "/portal(?:/(.*))?", "dest": "/portal.html" },
    { "src": "/adminportal(?:/(.*))?", "dest": "/adminportal.html" }
  ]
}
